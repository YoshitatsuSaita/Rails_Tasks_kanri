<% provide(:title, "Top") %>
<div class="row">
  <div class="col-md-7">   
    <div class="center jumbotron" id = "top-main">
      <h1 id= top-main-title>Task App</h1>
      <p>TaskAppは簡易ToDo管理ツールです。</p>

      <p>初めてのご利用</p>
      <center>
        <% if logged_in? && !current_user.admin? %>
        <%= link_to "アカウント作成", signup_path, class: "btn btn-lg btn-success" , disabled: true %>
        <% else %>
        <%= link_to "アカウント作成", signup_path, class: "btn btn-lg btn-success" %>
        <% end %>
      </center>
    </div>
  </div>
  <div class="col-md-4">
    <h1>ログイン</h1>
    <%= form_with(scope: :session, url: login_path, local: true) do |f| %>

      <%= f.label :email, class: "label-login" %>
      <%= f.email_field :email, class: 'form-control' , disabled: logged_in? %>

      <%= f.label :password, class: "label-login" %>
      <%= f.password_field :password, class: 'form-control', disabled: logged_in? %>
      
      <% if !logged_in?  %>
        <%= f.label :remember_me, class: "checkbox inline checkbox-login", for: "remember-me" do %>
          <%= f.check_box :remember_me, id: "remember-me" %>
          <span>ログイン情報を記憶する</span>
        <% end %>
      <% end %>

      <%= f.submit "ログイン", class: "btn btn-primary btn-block btn-login", disabled: logged_in? %>
    <% end %>
  </div>
</div>

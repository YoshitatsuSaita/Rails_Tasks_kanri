<% provide(:title, "users") %>

<div class="row">
  <div class="col-md-10 col-md-offset-1">
    <h1>利用者一覧</h1>
    <%= will_paginate @users , previous_label:"前" ,  next_label:"次" %>
    <table class="table table-hover">
      <thead>
        <tr><th>名称</th><th></th><th></th></tr>
      </thead>
      <tbody>
        <% @users.each do |user| %> 
          <tr>
            <td>
              <%= link_to user.name, user_path(user), class: "user-name"%>
              <% if user.admin? %>
                <span class="label label-primary">管理者</span>
              <% else %>
                <span class="label label-success">一般</span>
              <% end %>
            </td>
            <td></td>
            <td>
              <%= link_to "削除", user_path(user), method: :delete, data: { confirm: "【確認】#{user.name}を削除してもよろしいですか?" }, class: "btn btn-danger btn-detail" %>
            </td>
          </tr>
        <% end %>  
      </tbody>
    </table>
    <%= will_paginate @users , previous_label:"前" ,  next_label:"次" %>
  </div>    
</div>
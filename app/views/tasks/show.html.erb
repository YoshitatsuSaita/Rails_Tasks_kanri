<% provide(:title, @task.name) %>

<div class="row">
  <h1>タスク詳細</h1>
  <div class="col-md-10 col-md-offset-1">
    <table class="table table-bordered">
      <tr>
        <th class="active col-md-2"><%= Task.human_attribute_name :id %></th>
        <td class="col-md-10"><%= @task.id %></td>
      </tr>
      <tr>
        <th class="active"><%= Task.human_attribute_name :name %></th>
        <td><%= @task.name %></td>
      </tr>
      <tr>
        <th class="active"><%= Task.human_attribute_name :detail %></th>
        <td><%= raw Rinku.auto_link(simple_format(@task.detail)) %></td>
      </tr>
      <tr>
        <th class="active"><%= Task.human_attribute_name :created_at %></th>
        <td><%= @task.created_at %></td>
      </tr>
      <tr>
        <th class="active"><%= Task.human_attribute_name :updated_at %></th>
        <td><%= @task.updated_at %></td>
      </tr>
    </table>
    <div>
      <%= link_to "編集", edit_user_task_path(@user,@task), class: "btn btn-success btn-detail" %>
      <%= link_to "削除", user_task_path(@user, @task), method: :delete, class: "btn btn-danger btn-detail" %>
    </div>
  </div>    
</div>
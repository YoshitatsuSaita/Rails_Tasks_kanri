<% provide(:title, "tasks") %>
<div class="row">
  <div class="col-md-10 col-md-offset-1">
    <h1>タスク一覧</h1>
    <table class="table table-hover">
      <thead>
        <tr><th>名称</th><th>作成日</th></tr>
      </thead>
      <tbody>
        <% @tasks.each do |task| %> 
          <tr><td><%= task.name %></td><td><%= task.created_at %></td></tr>
        <% end %>  
      </tbody>
    </table>
  </div>    
</div>
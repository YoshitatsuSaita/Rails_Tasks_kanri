<% provide(:title, 'Edit Task') %>
<h1>タスク更新</h1>
<div class="row">
  <div class="col-md-6 col-md-offset-3">
    <%= form_with(model: @task, local: true, url: user_task_path(@user,@task)) do |f| %>
      <%= render 'shared/error_messages' , object: @task %>
      
      <%= f.label :name, class: "label-signup" %>
      <%= f.text_field :name, class: "form-control task-detail" %>

      <%= f.label :detail, class: "label-signup" %>
      <%= f.text_area :detail, class: "form-control task-detail", rows:5 %>

      <%= f.submit "更新", class: "btn btn-primary btn-signup" %>
    <% end %>
  </div>
</div>